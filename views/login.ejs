<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Connexion | Trading IA</title>
    <style>
        body { background: #050505; color: white; font-family: 'Segoe UI', sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
        .login-card { background: rgba(0, 20, 30, 0.8); border: 1px solid #00f3ff; padding: 40px; width: 350px; text-align: center; box-shadow: 0 0 20px rgba(0, 243, 255, 0.2); position: relative; }
        .login-card::before { content: ""; position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px; border: 1px solid #00f3ff; z-index: -1; clip-path: polygon(0 0, 10% 0, 0 10%); }
        h1 { text-transform: uppercase; letter-spacing: 4px; color: #00f3ff; font-size: 1.5rem; }
        input { width: 100%; padding: 12px; margin: 10px 0; background: rgba(0,0,0,0.5); border: 1px solid #00f3ff; color: white; box-sizing: border-box; }
        button#btn-login { width: 100%; padding: 15px; background: #00f3ff; border: none; color: black; font-weight: bold; cursor: pointer; text-transform: uppercase; margin-top: 20px; transition: 0.3s; }
        button#btn-login:hover { background: #00a8b3; box-shadow: 0 0 15px #00f3ff; }
        
        /* Bloc Erreur avec bouton de renvoi */
        #error-box { display: none; margin-bottom: 20px; padding: 10px; border: 1px solid #ff4444; background: rgba(255, 68, 68, 0.1); color: #ff4444; font-size: 0.9rem; }
        #btn-resend { display: none; margin-top: 10px; background: none; border: 1px solid #00f3ff; color: #00f3ff; padding: 5px; cursor: pointer; width: 100%; font-size: 0.8rem; }
    </style>
</head>
<body>

<div class="login-card">
    <h1>Connexion</h1>
    
    <div id="error-box">
        <span id="error-txt"></span>
        <button id="btn-resend" onclick="resendMail()">Renvoyer le mail de confirmation</button>
    </div>

    <form id="loginForm">
        <input type="email" name="email" placeholder="EMAIL" required>
        <input type="password" name="password" placeholder="MOT DE PASSE" required>
        <button type="submit" id="btn-login">Se Connecter</button>
    </form>
    
    <p style="font-size: 0.8rem; margin-top: 20px;">Pas de compte ? <a href="/register" style="color:#00f3ff;">S'inscrire</a></p>
</div>

<script>
    const loginForm = document.getElementById('loginForm');
    const errorBox = document.getElementById('error-box');
    const errorTxt = document.getElementById('error-txt');
    const btnResend = document.getElementById('btn-resend');

    loginForm.onsubmit = async (e) => {
        e.preventDefault();
        const formData = new URLSearchParams(new FormData(loginForm));
        
        const res = await fetch('/login', { method: 'POST', body: formData });
        const data = await res.json();

        if (data.error) {
            errorTxt.innerText = data.error;
            errorBox.style.display = 'block';
            
            // Si le message d'erreur contient "vérifier", on montre le bouton
            if (data.error.includes("vérifier")) {
                btnResend.style.display = 'block';
            } else {
                btnResend.style.display = 'none';
            }
        } else if (data.redirect) {
            window.location.href = data.redirect;
        }
    };

    async function resendMail() {
        const email = document.querySelector('input[name="email"]').value;
        const res = await fetch('/resend-email', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ email })
        });
        const data = await res.json();
        alert(data.success || data.error);
    }
</script>

</body>
</html>